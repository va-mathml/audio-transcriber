# ── Motor de transcripcion ───────────────────────────────────────────────────
# Key primaria - cuenta 1 en console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Key secundaria - cuenta 2 Groq (fallback si key1 agota cuota o falla)
GROQ_API_KEY_2=gsk_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Modelo key1: turbo = rapido, buena precision para audio conversacional
GROQ_MODEL=whisper-large-v3-turbo

# Modelo key2: large-v3 = maxima precision (se usa solo si key1 falla)
GROQ_MODEL_2=whisper-large-v3

# Idioma por defecto (es=español, en=ingles, dejar vacio=autodetectar)
TRANSCRIPTION_LANGUAGE=es

# ── Telegram ─────────────────────────────────────────────────────────────────
# Token del bot - obtener en @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# URL publica del backend en Railway (sin slash final)
WEBHOOK_URL=https://your-app.railway.app

# ── Limites ───────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL del frontend en Render (para CORS y referencia en root endpoint)
FRONTEND_URL=https://audio-transcriber.onrender.com

# Origenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=https://audio-transcriber.onrender.com
